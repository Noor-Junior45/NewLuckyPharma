{
  "framework": "vite",
  "rewrites": [
    {
      "source": "/((?!assets/|sitemap\\.xml|robots\\.txt|ads\\.txt|google.*\\.html|.*\\..*$).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}